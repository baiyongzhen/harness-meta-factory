# Harness Eval 컨테이너용 환경 변수
# cp .env.example .env 후 값을 채우세요.

# --- 일반 LLM API ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
HF_TOKEN=

# --- SkillOpt + 로컬 Ollama (OpenAI-compatible) ---
# Ollama는 /v1 OpenAI 호환 API 제공 → SkillOpt openai_chat 백엔드로 사용
# Docker에서 호스트 Ollama: host.docker.internal (Windows/macOS Docker Desktop)
OLLAMA_HOST=http://host.docker.internal:11434
AZURE_OPENAI_ENDPOINT=http://host.docker.internal:11434/v1
AZURE_OPENAI_API_KEY=ollama
AZURE_OPENAI_AUTH_MODE=openai_compatible
# train.py / eval_only.py 에서 --optimizer_model, --target_model 에 Ollama 모델명 지정
# 예: llama3.2, qwen2.5:7b
